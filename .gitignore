# Kotlin/Gradle build artifacts
build/
.gradle/
.kotlin/
*.class
*.jar
*.war
*.ear

# Keep the Gradle wrapper jar checked in so CI can run `./gradlew`.
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
out/

# Upstream Rust source — clone freshly when porting begins
tmp/
!tmp/.gitkeep

# AST distance reports and binaries
port_status_report.md
high_priority_ports.md
ast_distance_*.txt
.cache/
*.lock
kotlin-js-store/*
!kotlin-js-store/package.json
!kotlin-js-store/yarn.lock
!kotlin-js-store/wasm/
!kotlin-js-store/wasm/yarn.lock
tools/ast_distance/ast_distance
tools/ast_distance/build/

# JVM heap dumps
*.hprof
java_pid*.hprof

# macOS Finder metadata
.DS_Store

# Python bytecode
__pycache__/
*.pyc

# Android SDK
/.android-sdk/
local.properties

# Node N-API addon (node/) build artifacts and installed deps. The
# source (binding.gyp, src/openssl_shim.cc, package.json, index.js) is
# tracked; everything generated by `npm install` / `node-gyp build` is not.
/node/node_modules/
/node/build/
/node/package-lock.json

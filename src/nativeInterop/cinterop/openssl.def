headers = openssl/crypto.h openssl/sha.h openssl/evp.h openssl/bio.h openssl/ssl.h openssl/asn1.h openssl/err.h openssl/rand.h openssl/x509.h openssl/x509v3.h openssl/x509_vfy.h openssl/pem.h openssl/pkcs7.h openssl/ocsp.h openssl/dh.h openssl/dsa.h openssl/ec.h openssl/rsa.h openssl/srtp.h openssl/cms.h openssl/dtls1.h openssl/ssl3.h openssl/tls1.h openssl/aes.h openssl/obj_mac.h openssl/core_dispatch.h
package = openssl

# macOS: link against Homebrew openssl@3. The build host must have
# `brew install openssl@3`. Both Apple-silicon (/opt/homebrew) and Intel
# (/usr/local) prefixes are listed; the unused one is harmless.
compilerOpts.osx = -I/opt/homebrew/opt/openssl@3/include -I/usr/local/opt/openssl@3/include
linkerOpts.osx = -L/opt/homebrew/opt/openssl@3/lib -L/usr/local/opt/openssl@3/lib -lssl -lcrypto

# Linux: rely on the distro's libssl-dev / openssl-devel package providing
# headers under /usr/include/openssl and libssl/libcrypto on the default
# linker search path.
compilerOpts.linux = -I/usr/include
linkerOpts.linux = -lssl -lcrypto

# MinGW: matches the openssl package layout shipped by msys2's
# mingw-w64-x86_64-openssl. Override OPENSSL_PREFIX via Gradle properties
# if the host uses a different install root.
linkerOpts.mingw = -lssl -lcrypto
